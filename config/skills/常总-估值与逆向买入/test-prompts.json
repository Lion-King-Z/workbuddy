{
  "skill": "常总-估值与逆向买入",
  "tests": [
    {
      "prompt": "这个公司现在估值高不高？",
      "expected": "should_trigger",
      "reason": "直接询问估值贵贱。"
    },
    {
      "prompt": "PEG怎么看，现在多少倍算合理？",
      "expected": "should_trigger",
      "reason": "PEG估值判断。"
    },
    {
      "prompt": "现在暴跌能不能抄底？",
      "expected": "should_trigger",
      "reason": "逆向买入场景。"
    },
    {
      "prompt": "三低买入条件满足了吗？",
      "expected": "should_trigger",
      "reason": "三低买入法。"
    },
    {
      "prompt": "这个标的价格处于高位还是低位？",
      "expected": "should_trigger",
      "reason": "价格位置判断。"
    },
    {
      "prompt": "AI算力是不是长期超级赛道？",
      "expected": "should_not_trigger",
      "reason": "属于赛道稀缺卡位评估 skill。"
    },
    {
      "prompt": "这个板块放量了能不能追？",
      "expected": "should_not_trigger",
      "reason": "属于资金趋势识别 skill。"
    },
    {
      "prompt": "这个票跌了20%要不要卖？",
      "expected": "should_not_trigger",
      "reason": "属于持有纪律与公司排雷 skill。"
    },
    {
      "prompt": "帮我查一下这个公司的年报。",
      "expected": "should_not_trigger",
      "reason": "纯信息查询。"
    },
    {
      "prompt": "成长股PE 100倍，但净利润增速120%，PEG不到1，能不能买？",
      "expected": "edge_case",
      "reason": "高PE低PEG边界情况，需要验证增速可持续性。"
    }
  ]
}
